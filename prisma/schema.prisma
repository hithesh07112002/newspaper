generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  AGENT
  DELIVERY_BOY
  ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CustomerStatus {
  ACTIVE
  STOPPED
}

enum DeliveryStatus {
  PENDING
  DELIVERED
}

enum PaymentMode {
  CASH
  ONLINE
}

enum CollectionStatus {
  PAID
  PENDING
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  email        String?    @unique
  passwordHash String
  role         UserRole
  approvalStatus ApprovalStatus @default(APPROVED)
  deliveries   Delivery[]
  salaries     Salary[]
  assignedCustomers Customer[] @relation("AssignedCustomers")
  sessions     Session[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([role, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model Customer {
  id          String       @id @default(cuid())
  name        String
  area        String
  status      CustomerStatus @default(ACTIVE)
  assignedUserId String?
  assignedUser User?       @relation("AssignedCustomers", fields: [assignedUserId], references: [id], onDelete: SetNull)
  deliveries  Delivery[]
  collections Collection[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([assignedUserId])
}

model Delivery {
  id            String         @id @default(cuid())
  customerId    String
  customer      Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  date          DateTime
  ordered       Int
  delivered     Int
  deliveryBoyId String
  deliveryBoy   User           @relation(fields: [deliveryBoyId], references: [id], onDelete: Restrict)
  status        DeliveryStatus @default(PENDING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([date])
  @@index([customerId, date])
  @@index([deliveryBoyId, date])
}

model Collection {
  id          String           @id @default(cuid())
  customerId  String
  customer    Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  monthYear   String
  amount      Float
  paymentDate DateTime?
  dueDate     DateTime?
  mode        PaymentMode
  status      CollectionStatus
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([customerId, monthYear])
  @@index([monthYear, status])
}

model Salary {
  id            String   @id @default(cuid())
  deliveryBoyId String
  deliveryBoy   User     @relation(fields: [deliveryBoyId], references: [id], onDelete: Restrict)
  monthYear     String
  amount        Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([monthYear, deliveryBoyId])
}

model AppSetting {
  id        String   @id
  unitCost  Float    @default(5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
